; ==========================================
; SimForager Configuration Template (v2.x)
; ==========================================

; ===============================
; Grid / Model Dimensions
; ===============================

dim = 10000 10000 1
ecosystem-dim = 10000 10000 1

timesteps = 1000

infection-coords = random:10000
substrate-bitmap = <SUBSTRATE_FILE_PATH>

initial-infection = 1000

incubation-period = 0
apoptosis-period = 1000000
expressing-period = 1000000

infectivity = 0.9
infectivity-multiplier = 1.0

floating_algae-production = 1.1
floating_algae-production-multiplier = 1.0
floating_algae-clearance = 0.0
floating_algae-diffusion = 0.0

chemokine-production = 0.0
chemokine-decay = 0.0
chemokine-diffusion = 1.0
min-chemokine = 0.0

antibody-factor = 1
antibody-period = 1000000

; ===============================
; Fish Generation
; ===============================

fish-generation-rate = 10
fish-initial-delay = 0
fish-vascular-period = 2
fish-reef-period = 1000000
fish-binding-period = 2
max-binding-prob = 1

seed = 29

sample-period = 10
sample-resolution = 1
max-block-dim = 10

output = results

; ===============================
; Population Controls
; ===============================

num-fish = 10000
predator-ratio = 0

predator-detect-grazer-radius = 15
grazer-detect-predator-radius = 50

algae-initial-count = 100.0
algae-decomp-rate-from-grazing = 1.0

log_grazer_tracks = 0
log_population_stat = 1
log_fish_diagnostics = 1

; ===============================
; Social Movement Model (Density-Based)
; ===============================

social-strength = 1.0

social-density-radius = 50
social-neighbour-saturation = 20

social-sigmoid-midpoint = 0.5
social-sigmoid-steepness = 10.0

; κ targets for social modulation (low_density → high_density)

kappa_social_low_density_coral_w_algae  = 8
kappa_social_high_density_coral_w_algae = 2

kappa_social_low_density_coral_no_algae  = 14
kappa_social_high_density_coral_no_algae = 8

kappa_social_low_density_sand_w_algae  = 64
kappa_social_high_density_sand_w_algae = 8

kappa_social_low_density_sand_no_algae  = 72
kappa_social_high_density_sand_no_algae = 16

; Step length targets (low_density → high_density)
; Coupled to κ via v(κ)=0.01κ+0.08 (m/s) and step_len = 100v = κ+8 (cells/step)
; 10 s timestep, 10 cm cells

step_len_social_low_density_coral_w_algae  = 16
step_len_social_high_density_coral_w_algae = 10

step_len_social_low_density_coral_no_algae  = 22
step_len_social_high_density_coral_no_algae = 16

step_len_social_low_density_sand_w_algae  = 72
step_len_social_high_density_sand_w_algae = 16

step_len_social_low_density_sand_no_algae  = 80
step_len_social_high_density_sand_no_algae = 24
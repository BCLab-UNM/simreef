; ==========================================
; SimForager Configuration Template (v2.x)
; ==========================================

; ===============================
; Grid / Model Dimensions
; ===============================

dim = 10000 10000 1
ecosystem-dim = 10000 10000 1

timesteps = 1000

infection-coords = random:10000
substrate-bitmap = <SUBSTRATE_FILE_PATH>

initial-infection = 1000

incubation-period = 0
apoptosis-period = 1000000
expressing-period = 1000000

infectivity = 0.9
infectivity-multiplier = 1.0

floating_algae-production = 1.1
floating_algae-production-multiplier = 1.0
floating_algae-clearance = 0.0
floating_algae-diffusion = 0.0

chemokine-production = 0.0
chemokine-decay = 0.0
chemokine-diffusion = 1.0
min-chemokine = 0.0

antibody-factor = 1
antibody-period = 1000000

; ===============================
; Fish Generation
; ===============================

fish-generation-rate = 10
fish-initial-delay = 0
fish-vascular-period = 2
fish-reef-period = 1000000
fish-binding-period = 2
max-binding-prob = 1

seed = 29

sample-period = 200
sample-resolution = 1
max-block-dim = 64

output = results

; ===============================
; Population Controls
; ===============================

;num-fish = 512000
num-fish = 51200
predator-ratio = 0

predator-detect-grazer-radius = 15
grazer-detect-predator-radius = 50

algae-initial-count = 100.0
algae-decomp-rate-from-grazing = 1.0

log_grazer_tracks = 0
log_population_stat = 0
log_fish_diagnostics = 0

; ===============================
; Social Movement Model (Preferred Density)
; ===============================

social-strength = 1.0

social-density-radius = 50

; Preferred local neighbour count for strongest social behaviour
social-density-preferred = 10

; Width of transition from low-density behaviour up to preferred behaviour
social-density-low-width = 10

; Width of transition from preferred behaviour up to high-density behaviour
social-density-high-width = 10

; κ targets for social modulation
; low_density → preferred_density → high_density

social-density-preferred = 12
social-density-low-width = 6
social-density-high-width = 8

kappa_social_low_density_coral_w_algae        = 8
kappa_social_preferred_density_coral_w_algae  = 2
kappa_social_high_density_coral_w_algae       = 32

kappa_social_low_density_coral_no_algae       = 14
kappa_social_preferred_density_coral_no_algae = 8
kappa_social_high_density_coral_no_algae      = 40

kappa_social_low_density_sand_w_algae         = 64
kappa_social_preferred_density_sand_w_algae   = 8
kappa_social_high_density_sand_w_algae        = 64

kappa_social_low_density_sand_no_algae        = 72
kappa_social_preferred_density_sand_no_algae  = 16
kappa_social_high_density_sand_no_algae       = 72

step_len_social_low_density_coral_w_algae        = 16
step_len_social_preferred_density_coral_w_algae  = 10
step_len_social_high_density_coral_w_algae       = 40

step_len_social_low_density_coral_no_algae       = 22
step_len_social_preferred_density_coral_no_algae = 16
step_len_social_high_density_coral_no_algae      = 48

step_len_social_low_density_sand_w_algae         = 72
step_len_social_preferred_density_sand_w_algae   = 16
step_len_social_high_density_sand_w_algae        = 80

step_len_social_low_density_sand_no_algae        = 80
step_len_social_preferred_density_sand_no_algae  = 24
step_len_social_high_density_sand_no_algae       = 80